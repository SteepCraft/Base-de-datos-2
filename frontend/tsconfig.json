{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"]
    },
    "moduleResolution": "bundler",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": ["src", "src/types"],
  "exclude": ["node_modules", "dist", ".turbo"]
}
